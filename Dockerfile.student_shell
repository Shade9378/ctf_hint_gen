FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    bash \
    coreutils \
    python3 \
    python3-pip \
    curl \
    wget \
    git \
    file \
    binutils \
    netcat-openbsd \
    vim \
    gdb \
    strace \
    ltrace \
    unzip \
    zip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /student_shell

CMD ["sleep", "infinity"]